# Supabase — from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only, never exposed to the browser. Used by /admin
# server actions to write to tables that are read-only for anon/authenticated via RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin — single shared login at /admin (no user database, just these two)
ADMIN_EMAIL=change-me@example.com
ADMIN_PASSWORD=change-me
# Random long string used to sign the admin session cookie
ADMIN_SESSION_SECRET=generate-a-long-random-string

# Google Places API key (server-side only, used to fetch aggregate rating)
# Restrict this key to the Places API in Google Cloud Console, no HTTP referrer restriction
GOOGLE_PLACES_API_KEY=your-places-api-key
GOOGLE_PLACES_PLACE_ID=your-google-place-id

# Google Maps Embed API key — safe to expose to the browser, but restrict it in
# Google Cloud Console to the Maps Embed API + your site's HTTP referrers only
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=your-maps-embed-key

# Site
NEXT_PUBLIC_SITE_URL=https://mbtpoppysventersdorp.vercel.app
